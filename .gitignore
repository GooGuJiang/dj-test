# Python cache and bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Packaging and build artifacts
build/
dist/
*.egg-info/
.eggs/
*.egg

# Test, coverage, and type-check caches
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/
.tox/

# Jupyter / IPython
.ipynb_checkpoints/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs and temporary files
*.log
*.tmp
*.temp

# Environment and secrets
.env
.env.*
!.env.example

# Generated audio / analysis outputs
outputs/
output/
exports/
cache/
*.mp3
*.flac
*.aiff
*.aif
*.m4a

# Keep demo WAV files tracked unless explicitly removed
!demo_tracks/*.wav
